DATABASE_URL=postgresql+asyncpg://scada:scada123@localhost:5432/scada_reporter
SECRET_KEY=change-this-in-production-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=480

SCADA_LICENSE_REQUIRED=false
# SCADA_LICENSE_FILE=/etc/ekont-smart-report/license.jwt
# SCADA_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# SCADA_LICENSE_ALGORITHMS=RS256,ES256

OPC_UA_URL=opc.tcp://localhost:49320
OPC_UA_USERNAME=
OPC_UA_PASSWORD=

REDIS_URL=redis://localhost:6379/0

# Grafana connection (dashboard sync at startup)
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Grafana panel render (embed in reports) — empty = fall back to GRAFANA_USER/PASSWORD basic-auth
GRAFANA_SA_TOKEN=
GRAFANA_RENDER_TIMEOUT=30.0
GRAFANA_RENDER_WIDTH=1000
GRAFANA_RENDER_HEIGHT=500
