# =============================================================================
# EKONT SMART REPORT — Production Ortamı Örnek Yapılandırması
# =============================================================================
# Bu dosyayı .env olarak kopyalayın ve aşağıdaki placeholder değerleri
# gerçek production değerleriyle doldurun.
#
# SECRET_KEY üretmek için:
#   openssl rand -hex 32
# veya:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

ENVIRONMENT=production

# JWT imzalama anahtarı — MUTLAKA değiştirin, asla varsayılanı kullanmayın.
SECRET_KEY=<openssl rand -hex 32 çıktısını buraya yapıştırın>

# Bearer token ömrü — production'da mümkünse 60 dakika veya daha kısa tutun.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL bağlantısı — yerel/demo değer bırakmayın.
DATABASE_URL=postgresql+asyncpg://USER:GÜÇLÜ_PAROLA@db.sunucu.example:5432/scada_reporter

# İzin verilen frontend origin'leri (virgülle ayrılmış, wildcard kabul edilmez).
CORS_ORIGINS=https://scada.gercek-alan.example

# Bu process yalnızca API ise False yapın; collector ayrı process'te çalışsın.
RUN_COLLECTOR=False

# Bu process yalnızca API ise False yapın; scheduler ayrı process'te çalışsın.
RUN_SCHEDULER=False

# Otomatik tablo oluşturma — production'da False önerilir; Alembic migration kullanın.
# (Task 2 bu ayarı devreye alır; şimdilik placeholder.)
AUTO_CREATE_TABLES=False

# PostgreSQL'de tag_readings yazımı için asyncpg COPY kullan (INSERT yerine, ~3-10x hızlı)
# PostgreSQL/TimescaleDB kullanırken bu özelliği True yapmak önerilir.
S7_PG_COPY_INGEST=True

# PostgreSQL DB bağlantı havuzu
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (APScheduler / cache)
REDIS_URL=redis://redis:6379/0

# Grafana / Docker Compose parola örnekleri (docker/.env'e taşınabilir)
# GRAFANA_PASSWORD=<güçlü parola>
# POSTGRES_PASSWORD=<GÜÇLÜ_PAROLA ile aynı olmalı>

# Hata izleme (isteğe bağlı)
SENTRY_DSN=

# Tesis adı (raporlarda görünür)
FACILITY_NAME=Su/Atıksu Tesisi

# Ticari lisans doğrulama
# SCADA_LICENSE_TOKEN yerine dosya kullanmak production/on-prem için daha uygundur.
#
# Modlar (REQUIRED=false iken, public key tanımlıysa):
#   - geçerli lisans var  → licensed (claim'lere göre tam/kısıtlı)
#   - lisans yok/geçersiz → demo (salt-okuma, premium kapalı, tag görünürlüğü tavanlı)
# REQUIRED=true ise lisans zorunlu — yoksa/geçersizse backend BAŞLAMAZ (fail-closed).
# Public key tanımlı değilse (dev) → tam sürüm, kısıt yok.
# Lisans dosyası Settings'ten de yüklenebilir (admin); SCADA_LICENSE_FILE yazılabilir olmalı.
SCADA_LICENSE_REQUIRED=false
SCADA_LICENSE_FILE=/etc/ekont-smart-report/license.jwt
SCADA_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
SCADA_LICENSE_ALGORITHMS=RS256,ES256
SCADA_LICENSE_PRODUCT=ekont-smart-report
# Demo modunda görünür/izinli tag tavanı
SCADA_LICENSE_DEMO_MAX_TAGS=25
