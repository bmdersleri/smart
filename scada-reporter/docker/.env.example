# Docker local-infra credential overrides
# Copy this file to docker/.env before running docker compose in production.
# PRODUCTION MUST override these values — never ship the defaults.
#
# Usage:
#   cp scada-reporter/docker/.env.example scada-reporter/docker/.env
#   # Edit .env with real secrets, then:
#   cd scada-reporter/docker && docker compose up -d

POSTGRES_PASSWORD=
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=
