{
  "id": null,
  "uid": "scada-metrics-v1",
  "title": "SCADA — Prometheus Metrikleri",
  "description": "Backend poller/PLC sağlık metrikleri: tick süresi, PLC okuma gecikmesi, yazılan satır, BAD kalite, HTTP ve DB pool.",
  "tags": ["scada", "prometheus", "metrics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tick Süresi — p50 / p95 / p99",
      "description": "Poller tek tick süresi histogram quantile'leri (scada_tick_duration_seconds).",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(scada_tick_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(scada_tick_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(scada_tick_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PLC Okuma Gecikmesi — p95 (PLC başına)",
      "description": "PLC başına okuma süresi p95 (scada_plc_read_seconds label: plc).",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (plc, le) (rate(scada_plc_read_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{plc}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DB'ye Yazılan Satır Oranı",
      "description": "5 dakikalık pencerede yazılan satır hızı (scada_rows_written_total).",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(scada_rows_written_total[5m])",
          "legendFormat": "rows/s",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "BAD Kalite Oranı",
      "description": "5 dakikalık pencerede BAD-kalite okuma hızı (scada_bad_quality_total).",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(scada_bad_quality_total[5m])",
          "legendFormat": "bad/s",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP İstek Oranı (status başına)",
      "description": "HTTP istek oranı status kodu başına (scada_http_requests_total[method, status]).",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(scada_http_requests_total[5m]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Gecikme p95 (method başına)",
      "description": "HTTP istek süresi p95 method başına (scada_http_request_seconds).",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (method, le) (rate(scada_http_request_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{method}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Bağlantı Havuzu",
      "description": "DB pool boyutu ve kullanımdaki bağlantı sayısı (scada_db_pool_size, scada_db_pool_checked_out).",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "scada_db_pool_size",
          "legendFormat": "pool_size",
          "refId": "A"
        },
        {
          "expr": "scada_db_pool_checked_out",
          "legendFormat": "checked_out",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Aktif WebSocket Bağlantıları",
      "description": "Canlı Dashboard (Live Stream) WebSocket bağlantı sayısı.",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "scada_active_websockets",
          "legendFormat": "Aktif Cihaz",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP 5xx (Sunucu Hataları) Oranı",
      "description": "Son 5 dakikadaki sunucu taraflı çökme ve hataların saniyelik oranı.",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (method, status) (rate(scada_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
