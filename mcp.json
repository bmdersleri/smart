{
  "mcpServers": {
    "scada": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/mcp-scada", "mcp-server-scada"],
      "env": {
        "SCADA_API_URL": "http://localhost:8001",
        "SCADA_TOKEN": ""
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    }
  }
}
